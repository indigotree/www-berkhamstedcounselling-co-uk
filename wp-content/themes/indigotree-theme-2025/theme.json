				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text": "var(--wp--preset--color--white)"
				},
				"spacing": {
					"padding": {
						"bottom": "15px",
						"left": "15px",
						"right": "15px",
						"top": "15px"
					}
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--base)",
					"fontSize": "20px",
					"fontWeight": "700",
					"lineHeight": "20px",
					"textDecoration": "none"
				},
				"hover":{
					"color": {
						"background": "var(--wp--preset--color--white)",
						"text": "var(--wp--preset--color--primary)"
					}
				}
			},
