				{
					"color": "#C2C2C2",
					"name": "Grey",
					"slug": "grey"
				},
				{
					"color": "#F7F7F7",
					"name": "Light Grey",
					"slug": "light-grey"
				},
				{
					"color": "#DADADA",
					"name": "Extra Light Grey",
					"slug": "extra-light-grey"
				},
				{
					"color": "#FA941B",
