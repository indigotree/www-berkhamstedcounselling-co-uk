					"name": "Primary to Black Vertical Bottom",
					"slug": "primary-to-black-vertical-bottom"
				},
				{
					"gradient": "linear-gradient(180deg,var(--wp--preset--color--primary) 0%,var(--wp--preset--color--black) 100%)",
					"name": "Primary to Black Vertical Top",
					"slug": "primary-to-black-vertical-top"
				},
				{
					"gradient": "linear-gradient(90deg,var(--wp--preset--color--primary) 0%,var(--wp--preset--color--black) 100%)",
					"name": "Primary to Black Horizontal Left",
					"slug": "primary-to-black-horizontal-left"
