				"carousel": {
					"carousel-slide": {
						"arrow-next": {
							"right": "-100px"
						},
						"arrow-prev": {
							"left": "-100px"
						},
						"border-radius": "0"
					},
					"carousel-slide-query": {
						"border-radius": "0",
						"column-gap": "0",
						"featured-image-aspect-ratio": "1.75",
						"hover-box-shadow": "0 0 10px rgba(0, 0, 0, 0.5)",
						"row-gap": "0"
					},
					"focus-outline-color": "#007aff"
				},
				"site-navigation": {
					"li": {
						"ul": {
							"min-1280": {
								"background-color": "#ffffff"
							}
						}
					}
				},
				"table-of-contents": {
					"link-color": "var(--wp--preset--color--primary)",
					"link-hover-text-decoration": "underline"
				},
				"timeline": {
					"editor": {
						"padding-bottom": "88px"
					},
					"gap": "40px",
					"line-between-nodes": {
						"background": "var(--wp--preset--color--black)",
						"bottom": "-40px",
						"height": "40px",
						"left": "50px",
						"width": "12px"
					}
				}
			},
			"line-height": {
				"base": "1.45",
				"heading": "1.15"
			},
			"transition": "all 0.3s ease-in-out"
